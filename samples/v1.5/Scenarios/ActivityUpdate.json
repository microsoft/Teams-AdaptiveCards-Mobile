{
  "type": "AdaptiveCard",
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "version": "1.2",
  "body": [
    {
      "type": "TextBlock",
      "text": "Toggle Visibility Bug Repro",
      "weight": "Bolder",
      "size": "Large"
    },
    {
      "type": "TextBlock",
      "text": "Tap 'Show history' - it should switch to 'Hide history'. Bug: both disappear.",
      "wrap": true,
      "isSubtle": true
    },
    {
      "type": "ColumnSet",
      "columns": [
        {
          "type": "Column",
          "id": "showHistoryCol",
          "selectAction": {
            "type": "Action.ToggleVisibility",
            "title": "show history",
            "targetElements": [
              "historyContent",
              "hideHistoryCol",
              "showHistoryCol"
            ]
          },
          "verticalContentAlignment": "Center",
          "items": [
            {
              "type": "TextBlock",
              "horizontalAlignment": "Right",
              "color": "Accent",
              "text": "Show history",
              "wrap": true
            }
          ],
          "width": 1
        },
        {
          "type": "Column",
          "id": "hideHistoryCol",
          "isVisible": false,
          "selectAction": {
            "type": "Action.ToggleVisibility",
            "title": "hide history",
            "targetElements": [
              "historyContent",
              "hideHistoryCol",
              "showHistoryCol"
            ]
          },
          "verticalContentAlignment": "Center",
          "items": [
            {
              "type": "TextBlock",
              "horizontalAlignment": "Right",
              "color": "Accent",
              "text": "Hide history",
              "wrap": true
            }
          ],
          "width": 1
        }
      ]
    },
    {
      "type": "Container",
      "id": "historyContent",
      "isVisible": false,
      "items": [
        {
          "type": "TextBlock",
          "text": "This is the history content that appears when expanded.",
          "wrap": true
        }
      ]
    }
  ]
}