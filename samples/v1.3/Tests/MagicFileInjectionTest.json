{
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "type": "AdaptiveCard",
  "version": "1.3",
  "body": [
    {
      "type": "TextBlock",
      "text": "Font Rendering Test",
      "size": "Large",
      "weight": "Bolder",
      "isSubtle": false
    },
    {
      "type": "TextBlock",
      "text": "This card exercises font rendering with various sizes, weights, and font families to verify nil-font fallback behavior.",
      "wrap": true
    },
    {
      "type": "TextBlock",
      "text": "Default font \u2014 Normal weight",
      "size": "Default",
      "weight": "Default"
    },
    {
      "type": "TextBlock",
      "text": "Small Lighter Text",
      "size": "Small",
      "weight": "Lighter",
      "isSubtle": true
    },
    {
      "type": "TextBlock",
      "text": "Medium Bold Text",
      "size": "Medium",
      "weight": "Bolder"
    },
    {
      "type": "TextBlock",
      "text": "Extra Large Text",
      "size": "ExtraLarge",
      "weight": "Bolder"
    },
    {
      "type": "ColumnSet",
      "columns": [
        {
          "type": "Column",
          "width": "auto",
          "items": [
            {
              "type": "TextBlock",
              "text": "\u25b6",
              "id": "sourcesChevron"
            }
          ]
        },
        {
          "type": "Column",
          "width": "stretch",
          "items": [
            {
              "type": "TextBlock",
              "text": "Sources",
              "weight": "Bolder"
            }
          ]
        }
      ],
      "selectAction": {
        "type": "Action.ToggleVisibility",
        "targetElements": [
          "sourcesContainer"
        ]
      }
    },
    {
      "type": "Container",
      "id": "sourcesContainer",
      "isVisible": false,
      "items": [
        {
          "type": "TextBlock",
          "text": "1. [Adaptive Cards Documentation](https://adaptivecards.io)",
          "wrap": true
        },
        {
          "type": "TextBlock",
          "text": "2. [Font Metrics API Reference](https://developer.apple.com/documentation/uikit/uifontmetrics)",
          "wrap": true
        },
        {
          "type": "TextBlock",
          "text": "3. [UIFont fontWithDescriptor](https://developer.apple.com/documentation/uikit/uifont)",
          "wrap": true
        }
      ]
    }
  ]
}
